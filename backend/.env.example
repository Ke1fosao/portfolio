# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_SITE_URL=http://127.0.0.1:5173

# Telegram notifications
# Create a NEW token in @BotFather because a token pasted into chat must be considered compromised.
TELEGRAM_BOT_TOKEN=paste-new-bot-token-here
TELEGRAM_ALLOWED_CHAT_IDS=123456789
# Mini App must use a public HTTPS URL in Telegram.
TELEGRAM_WEBAPP_URL=https://your-domain.example/telegram-app
TELEGRAM_INIT_DATA_MAX_AGE=3600
# Run: python manage.py run_telegram_bot
# Send /start to the bot, then choose recipients in /admin/notifications.
# TELEGRAM_CHAT_ID is optional fallback for old single-recipient setups.
TELEGRAM_CHAT_ID=

# Email notifications (example for Gmail SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_HOST_USER=your-account@gmail.com
EMAIL_HOST_PASSWORD=paste-google-app-password-here
DEFAULT_FROM_EMAIL=your-account@gmail.com
ADMIN_NOTIFICATION_EMAIL=your-account@gmail.com
EMAIL_TIMEOUT=10

# Anti-spam / rate limits
LEAD_BURST_RATE=2/minute
LEAD_HOURLY_RATE=5/hour

# Backups and admin hardening
PORTFOLIO_BACKUP_DIR=../backups
PORTFOLIO_BACKUP_AUTO_FREQUENCY=off
DJANGO_ENABLE_HSTS=0
DJANGO_HSTS_SECONDS=31536000
