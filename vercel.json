{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && corepack pnpm install --frozen-lockfile",
  "buildCommand": "cd frontend && corepack pnpm run build",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
